# Google Cloud Configuration
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
BQ_DATASET=veda_ma_diligence

# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Google OAuth 2.0 Configuration
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# Session Configuration
SESSION_SECRET=your-random-session-secret-key-min-32-chars

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8001

# Vertex AI Configuration
VERTEX_AI_MODEL=gemini-2.5-flash

# Agent Timeout Configuration (in seconds)
AGENT_TIMEOUT_CODE=120
AGENT_TIMEOUT_REGULATORY=90
AGENT_TIMEOUT_MARKET=180
AGENT_TIMEOUT_SUMMARY=60
